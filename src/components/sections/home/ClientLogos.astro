---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Type definition for client logo
type ClientSize = "default" | "large";

type Client = {
  name: string;
  src: ImageMetadata;
  size: ClientSize;
};

// Helper function to get logo dimensions based on size
const getLogoDimensions = (size: ClientSize) => {
  return size === "large"
    ? { width: 1200, height: 1200 }
    : { width: 300, height: 300 };
};

// Import all logo images from assets folder using absolute path
const logoModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/logos/*.png",
  {
    eager: true,
    import: "default",
  },
);

// Helper function to get logo image by filename
const getLogo = (filename: string): ImageMetadata => {
  const key = `/src/assets/logos/${filename}`;
  const logo = logoModules[key];
  if (!logo) {
    throw new Error(`Logo not found: ${filename}`);
  }
  return logo;
};

const clientsRow1: Client[] = [
  { name: "Pertamina", src: getLogo("pertamina.png"), size: "large" },
  { name: "Samsung", src: getLogo("samsung.png"), size: "default" },
  { name: "Grab", src: getLogo("grab.png"), size: "default" },
  { name: "Prudential", src: getLogo("prudential.png"), size: "default" },
  { name: "Pegadaian", src: getLogo("pegadaian.png"), size: "default" },
  { name: "BCA", src: getLogo("bca.png"), size: "default" },
  { name: "BRI", src: getLogo("bri.png"), size: "default" },
  { name: "Viu", src: getLogo("viu.png"), size: "default" },
  { name: "OCBC", src: getLogo("ocbc.png"), size: "large" },
  { name: "Narasi", src: getLogo("narasi.png"), size: "large" },
  { name: "Ancol", src: getLogo("ancol.png"), size: "default" },
  { name: "ASDP", src: getLogo("asdp.png"), size: "default" },
  { name: "Telkomsel", src: getLogo("telkomsel.png"), size: "large" },
  { name: "Patra Jasa", src: getLogo("patra-jasa.png"), size: "large" },
  { name: "Cargill", src: getLogo("cargill.png"), size: "default" },
];

const clientsRow2: Client[] = [
  { name: "Jasa Marga", src: getLogo("jasa-marga.png"), size: "default" },
  { name: "KOMDIGI", src: getLogo("komdigi.png"), size: "default" },
  { name: "Telkom Indonesia", src: getLogo("telkom.png"), size: "default" },
  { name: "BNI", src: getLogo("bni.png"), size: "default" },
  { name: "Unilever", src: getLogo("unilever.png"), size: "default" },
  { name: "Vivo", src: getLogo("vivo.png"), size: "default" },
  { name: "Suzuki", src: getLogo("suzuki.png"), size: "default" },
  { name: "Shopee", src: getLogo("shopee.png"), size: "default" },
  { name: "Kemenkes", src: getLogo("kemenkes.png"), size: "large" },
  { name: "IM3", src: getLogo("im3.png"), size: "default" },
  { name: "Hello Sehat", src: getLogo("hello-sehat.png"), size: "large" },
  { name: "BNN", src: getLogo("bnn.png"), size: "default" },
  { name: "Shell", src: getLogo("shell.png"), size: "default" },
  {
    name: "Indonesia Eximbank",
    src: getLogo("indonesia-eximbank.png"),
    size: "large",
  },
  {
    name: "Kementrian Kehutanan",
    src: getLogo("kemenhut.png"),
    size: "default",
  },
  {
    name: "European Climate Foundation",
    src: getLogo("european-climate-foundation.png"),
    size: "large",
  },
];

// Duplikasi untuk efek seamless infinite scroll
const row1: Client[] = [...clientsRow1, ...clientsRow1];
const row2: Client[] = [...clientsRow2, ...clientsRow2];
---

<section class="py-24 bg-slate-950 overflow-hidden relative">
  <!-- Background Pattern -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute inset-0 bg-dot-grid opacity-[0.02]"></div>
    <div
      class="absolute top-0 right-0 w-[400px] h-[400px] bg-cyan-500/5 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-teal-500/5 rounded-full blur-3xl"
    >
    </div>
  </div>

  <div class="container mx-auto px-6 mb-16 text-center relative z-10">
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 mb-6"
    >
      <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
      <span
        class="text-[10px] font-black text-cyan-400 uppercase tracking-[0.3em]"
        >Our Network</span
      >
    </div>
    <h2 class="text-4xl md:text-5xl font-black text-white tracking-tighter">
      Dipercaya oleh <span
        class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-teal-400"
        >Brand Ternama</span
      >
    </h2>
  </div>

  <div class="flex flex-col gap-8 md:gap-12 relative">
    <div class="relative flex overflow-hidden group">
      <div
        class="flex animate-marquee-left whitespace-nowrap gap-12 md:gap-20 items-center py-4"
      >
        {
          row1.map((client) => {
            const { width, height } = getLogoDimensions(client.size);
            return (
              <div class="w-32 md:w-48 flex-shrink-0 flex items-center justify-center grayscale opacity-30 hover:grayscale-0 hover:opacity-100 hover:scale-110 transition-all duration-500 ease-out cursor-pointer">
                <Image
                  src={client.src}
                  alt={client.name}
                  class="max-h-16 md:max-h-16 w-auto object-contain invert brightness-0 hover:invert-0 hover:brightness-100"
                  width={width}
                  height={height}
                  loading="lazy"
                />
              </div>
            );
          })
        }
      </div>
    </div>

    <div class="relative flex overflow-hidden group">
      <div
        class="flex animate-marquee-right whitespace-nowrap gap-12 md:gap-20 items-center py-4"
      >
        {
          row2.map((client) => {
            const { width, height } = getLogoDimensions(client.size);
            return (
              <div class="w-32 md:w-48 flex-shrink-0 flex items-center justify-center grayscale opacity-30 hover:grayscale-0 hover:opacity-100 hover:scale-110 transition-all duration-500 ease-out cursor-pointer">
                <Image
                  src={client.src}
                  alt={client.name}
                  class="max-h-16 md:max-h-16 w-auto object-contain invert brightness-0 hover:invert-0 hover:brightness-100"
                  width={width}
                  height={height}
                  loading="lazy"
                />
              </div>
            );
          })
        }
      </div>
    </div>

    <div
      class="absolute inset-y-0 left-0 w-24 md:w-64 bg-gradient-to-r from-slate-950 via-slate-950/80 to-transparent z-10 pointer-events-none"
    >
    </div>
    <div
      class="absolute inset-y-0 right-0 w-24 md:w-64 bg-gradient-to-l from-slate-950 via-slate-950/80 to-transparent z-10 pointer-events-none"
    >
    </div>
  </div>
</section>

<style>
  /* Animasi ke Kiri */
  @keyframes marquee-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Animasi ke Kanan */
  @keyframes marquee-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .animate-marquee-left {
    animation: marquee-left 50s linear infinite;
  }

  .animate-marquee-right {
    animation: marquee-right 55s linear infinite;
  }

  /* Efek berhenti saat hover pada baris tersebut */
  .group:hover .animate-marquee-left,
  .group:hover .animate-marquee-right {
    animation-play-state: paused;
  }

  /* Responsivitas Kecepatan di Mobile */
  @media (max-width: 768px) {
    .animate-marquee-left {
      animation-duration: 30s;
    }
    .animate-marquee-right {
      animation-duration: 35s;
    }
  }
</style>
